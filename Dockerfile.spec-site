FROM --platform=$BUILDPLATFORM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum* ./
COPY docs ./docs
COPY cmd/spec-site-gen ./cmd/spec-site-gen
RUN mkdir -p /out && go run ./cmd/spec-site-gen -in docs/ggp-cell-v1.md -out /out/index.html

FROM caddy:2-alpine
COPY Caddyfile.spec-site /etc/caddy/Caddyfile
COPY --from=build /out /srv
