FROM --platform=$BUILDPLATFORM golang:1.25-alpine AS build
WORKDIR /src
ARG TARGETOS
ARG TARGETARCH
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH go build -o /out/blobfield ./cmd/blobfield

FROM alpine:3.22
RUN adduser -D -u 10001 game
WORKDIR /app
COPY --from=build /out/blobfield /app/blobfield
USER game
EXPOSE 8082
ENTRYPOINT ["/app/blobfield"]
