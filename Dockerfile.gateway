FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN go build -o /out/gateway ./cmd/gateway

FROM alpine:3.22
RUN adduser -D -u 10001 gateway
WORKDIR /app
COPY --from=build /out/gateway /app/gateway
USER gateway
EXPOSE 2222
ENTRYPOINT ["/app/gateway"]
